# ── DJANGO ─────────────────────────────────────────
SECRET_KEY=your-very-long-secret-key-here-change-in-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── DATABASE ────────────────────────────────────────
DB_NAME=dao_db
DB_USER=dao_user
